def setup_clients(region_name=REGION_NAME):
    """Set up the necessary AWS clients using the notebook's IAM role"""
    print("Setting up AWS clients...")
    
    # Create clients using the default session (SageMaker notebook's IAM role)
    s3_client = boto3.client('s3', region_name=region_name)
    bedrock_runtime = boto3.client('bedrock-runtime', region_name=region_name)
    
    return s3_client, bedrock_runtime

def setup_opensearch_client(config, region_name=REGION_NAME):
    """Set up OpenSearch client using the notebook's IAM role"""
    print("Setting up OpenSearch client using notebook's IAM role...")
    
    # Use the default session credentials (SageMaker notebook's IAM role)
    session = boto3.Session(region_name=region_name)
    credentials = session.get_credentials()
    
    # Create AWSV4SignerAuth using the session credentials
    auth = AWSV4SignerAuth(credentials, region_name, 'es')  # Use 'es' for OpenSearch VPC
    
    # Create the client
    client = OpenSearch(
        hosts=[{'host': config['host'], 'port': config['port']}],
        http_auth=auth,
        use_ssl=config['use_ssl'],
        verify_certs=True,
        connection_class=RequestsHttpConnection,
        timeout=60,
        http_compress=True,
        retry_on_timeout=True,
        max_retries=3
    )
    
    return client


# Initialize clients using the notebook's IAM role
