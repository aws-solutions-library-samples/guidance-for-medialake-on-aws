  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx,json,css,scss}": [
      "prettier --write"
    ],
    "src/**/*.{ts,tsx}": [
      "eslint --max-warnings=0 --rule '@typescript-eslint/no-unused-vars: error' --rule 'no-unused-vars: error'"
    ]
  },
  "name": "medialake",
  "private": true,
  "scripts": {
    "build": "NODE_OPTIONS='--max-old-space-size=2560' tsc && NODE_OPTIONS='--max-old-space-size=2560' vite build",
    "dev": "vite",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,scss}\"",
    "prepare": "husky install",
    "preview": "vite preview",
    "start": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report test-results/playwright-report",
    "test:perf": "playwright test --config=playwright.perf.config.ts",
    "test:perf:compare": "npx tsx tests/performance/compare-benchmarks.ts",
    "test:collections": "playwright test --config=playwright.collections.config.ts",
    "test:collections:crud": "playwright test --config=playwright.collections.config.ts collection-crud",
    "test:collections:sharing": "playwright test --config=playwright.collections.config.ts collection-sharing",
    "test:collections:groups": "playwright test --config=playwright.collections.config.ts collection-groups",
    "test:collections:subcollections": "playwright test --config=playwright.collections.config.ts sub-collections"
  },
  "type": "module",
  "version": "0.1.0"
}
