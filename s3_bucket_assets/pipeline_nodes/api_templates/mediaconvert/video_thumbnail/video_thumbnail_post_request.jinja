{
  "Role": "{{ variables.mediaconvert_role_arn }}",
  "Queue": "{{ variables.mediaconvert_queue }}",
  "Settings": {
    "Inputs": [
      {
        "FileInput": "s3://{{ variables.input_bucket }}/{{ variables.input_key }}",
        "AudioSelectors": {
          "Audio Selector 1": {
            "DefaultSelection": "DEFAULT"
          }
        },
        "VideoSelector": {}
      }
    ],
    "OutputGroups": [
      {
        "Name": "Thumbnail",
        "OutputGroupSettings": {
          "Type": "FILE_GROUP_SETTINGS",
          "FileGroupSettings": {
            "Destination": "s3://{{ variables.output_bucket }}/{{ variables.output_key }}",
            "DestinationSettings": {
              "S3Settings": {
                "AccessControl": {
                  "CannedAcl": "BUCKET_OWNER_FULL_CONTROL"
                }
              }
            }
          }
        },
        "Outputs": [
          {
            "NameModifier": "_thumbnail",
            "Extension": "jpg",
            "VideoDescription": {
              "CodecSettings": {
                "Codec": "FRAME_CAPTURE",
                "FrameCaptureSettings": {
                  {% if variables.duration_frames %}
                  "FramerateNumerator": 1,
                  "FramerateDenominator": {{ (variables.duration_frames * 0.25)|int }},
                  {% else %}
                  "FramerateNumerator": 1,
                  "FramerateDenominator": 4,
                  {% endif %}
                  "MaxCaptures": 1,
                  "Quality": 80
                }
              },
              "Width": {{ variables.thumbnail_width }},
              "Height": {{ variables.thumbnail_height }}
            },
            "ContainerSettings": {
              "Container": "RAW"
            }
          }
        ]
      }
    ]
  }
}