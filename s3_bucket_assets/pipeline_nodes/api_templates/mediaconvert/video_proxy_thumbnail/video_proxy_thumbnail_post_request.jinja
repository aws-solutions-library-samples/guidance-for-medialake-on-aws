{
  "Role": "{{ variables.mediaconvert_role_arn }}",
  "Queue": "{{ variables.mediaconvert_queue_arn }}",
  "Settings": {
    "Inputs": [
      {
        "FileInput": "s3://{{ variables.input_bucket }}/{{ variables.input_key }}",
        "AudioSelectors": {
          "Audio Selector 1": {
            "DefaultSelection": "DEFAULT"
          }
        },
        "VideoSelector": {}
      }
    ],

    "OutputGroups": [
      {
        "Name": "Proxy Video",
        "OutputGroupSettings": {
          "Type": "FILE_GROUP_SETTINGS",
          "FileGroupSettings": {
            "Destination": "s3://{{ variables.output_bucket }}/{{ variables.output_key }}",
            "DestinationSettings": {
              "S3Settings": {
                "AccessControl": {
                  "CannedAcl": "BUCKET_OWNER_FULL_CONTROL"
                }
              }
            }
          }
        },
        "Outputs": [
          {
            "NameModifier": "_proxy",
            "VideoDescription": {
              "Width": 640,
              "Height": 360,
              "CodecSettings": {
                "Codec": "H_264",
                "H264Settings": {
                  "RateControlMode": "QVBR",
                  "QualityTuningLevel": "MULTI_PASS_HQ",
                  "QvbrSettings": {
                    "QvbrQualityLevel": {{ variables.proxy_qvbr_quality | default(6) }}
                  },
                  {% if variables.proxy_max_avg_kbps is defined %}
                  "MaxAverageBitrate": {{ variables.proxy_max_avg_kbps * 1000 }},
                  {% endif %}
                  "SceneChangeDetect": "TRANSITION_DETECTION",
                  "MaxBitrate": {{ (variables.proxy_max_kbps | default(900)) * 1000 }}
                }
              }
            },
            "AudioDescriptions": [
              {
                "CodecSettings": {
                  "Codec": "AAC",
                  "AacSettings": {
                    "Bitrate": {{ (variables.proxy_audio_kbps | default(64)) * 1000 }},
                    "CodingMode": "CODING_MODE_2_0",
                    "SampleRate": 44100
                  }
                }
              }
            ],
            "ContainerSettings": {
              "Container": "MP4",
              "Mp4Settings": {
                "MoovPlacement": "PROGRESSIVE_DOWNLOAD"
              }
            }
          }
        ]
      },
      {
        "Name": "Thumbnail",
        "OutputGroupSettings": {
          "Type": "FILE_GROUP_SETTINGS",
          "FileGroupSettings": {
            "Destination": "s3://{{ variables.output_bucket }}/{{ variables.output_key }}"
          }
        },
        "Outputs": [
          {
            "NameModifier": "_thumbnail",
            "Extension": "jpg",
            "VideoDescription": {
              "Width": {{ variables.thumbnail_width }},
              "Height": {{ variables.thumbnail_height }},
              "CodecSettings": {
                "Codec": "FRAME_CAPTURE",
                "FrameCaptureSettings": {
                  {% if variables.duration_frames %}
                  "FramerateNumerator": 1,
                  "FramerateDenominator": {{ (variables.duration_frames * 0.25) | int }},
                  {% else %}
                  "FramerateNumerator": 1,
                  "FramerateDenominator": 4,
                  {% endif %}
                  "MaxCaptures": 1,
                  "Quality": 80
                }
              }
            },
            "ContainerSettings": { "Container": "RAW" }
          }
        ]
      }
    ]
  }
}
