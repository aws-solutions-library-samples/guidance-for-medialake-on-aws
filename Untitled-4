import boto3

CLOUD_DESKTOP = "cloud_desktop"
BETA="beta"
PREPROD="preprod"
PROD="prod"

def get_bedrock_client(env, region='us-east-1'):
    endpoints = {
        CLOUD_DESKTOP:'http://dev-dsk-apenac-2c-467bda57.us-west-2.amazon.com:8080',
        BETA: 'https://beta.us-east-1.dataplane.bedrock.aws.dev',
        PREPROD: 'https://preprod.us-east-1.dataplane.bedrock.aws.dev',
        PROD: 'https://bedrock-runtime.{}.amazonaws.com'
    }
    
    if env not in endpoints:
        raise ValueError(f"Invalid environment. Choose from: {', '.join(endpoints.keys())}")
    
    if env == PROD:
        return boto3.client('bedrock-runtime', region_name=region)
    else:
        return boto3.client('bedrock-runtime', 
                          endpoint_url=endpoints[env],
                          region_name=region)

def start_async_invoke_model(bedrock):
    RES = bedrock.start_async_invoke(
        modelId=f"twelvelabs.marengo-embed-2-7-v1:0",
        modelInput={
                "inputType": "text",
                "inputText": "man walking a dog"
            },
        outputDataConfig={
            "s3OutputDataConfig": {
                "s3Uri": "s3://uat-test-assets-034362036763-us-east-1/test-text-embed"
            }
        },
        tags=[{"key":"key", "value":"value"}]
    )

def lambda_handler(event, context):
    bedrock = get_bedrock_client(env=PREPROD)
    start_async_invoke_model(bedrock)