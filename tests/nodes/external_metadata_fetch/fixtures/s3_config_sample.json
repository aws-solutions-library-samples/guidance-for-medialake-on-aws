  "people_field_mappings": {
    "actors": "Actor",
    "directors": "Director",
    "writers": "Writer",
    "producers": "Producer",
    "series_creators": "Creator",
    "guest_actors": "Actor"
  },

  "person_first_name_attr": "@first_name",
  "person_last_name_attr": "@last_name",
  "person_order_attr": "@order",
  "person_role_attr": "@role",
  "guest_actors_field": "guest_actors"
}
