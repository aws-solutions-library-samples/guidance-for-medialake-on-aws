  "title_brief_field": "titlebrief",
  "premiere_year_field": "premiere_year",
  "original_air_date_field": "original_air_date",
  "country_code_field": "country_code",
  "language_field": "language",

  "identifier_mappings": {
    "acme_id": "",
    "refid": "-REF",
    "version_id": "-VERSION",
    "id_sequence": "-SEQ",
    "tms_series_id": "TMS",
    "tms_episode_id": "TMS",
    "tms_movie_id": "TMS",
    "ad_content_id": "-AD"
  },

  "title_mappings": {
