{
  "Comment": "State machine for pipeline TwelveLabs API Image Embedding to OpenSearch",
  "StartAt": "Presigned_URL_Generator_generate__dndnode_1_",
  "States": {
    "Embedding_Store_store__dndnode_5_": {
      "End": true,
      "Result": {
        "message": "No Lambda function for embedding_store"
      },
      "Type": "Pass"
    },
    "Presigned_URL_Generator_generate__dndnode_1_": {
      "Next": "TwelveLabs_post_generateImageOrAudioEmbeddings__dndnode_2_",
      "Result": {
        "message": "No Lambda function for pre_signed_url"
      },
      "Type": "Pass"
    },
    "TwelveLabs_post_generateImageOrAudioEmbeddings__dndnode_2_": {
      "Next": "Embedding_Store_store__dndnode_5_",
      "Resource": "arn:aws:lambda:us-east-1:123456789012:function:twelve_labs",
      "Retry": [
        {
          "BackoffRate": 2.0,
          "ErrorEquals": [
            "MediaConvert.ThrottlingException",
            "MediaConvert.TooManyRequestsException",
            "MediaConvertEndpointThrottlingError"
          ],
          "IntervalSeconds": 2,
          "MaxAttempts": 8
        },
        {
          "BackoffRate": 2.0,
          "ErrorEquals": ["Lambda.TooManyRequestsException"],
          "IntervalSeconds": 1,
          "MaxAttempts": 5
        },
        {
          "BackoffRate": 2.0,
          "ErrorEquals": ["States.ALL"],
          "IntervalSeconds": 2,
          "MaxAttempts": 3
        }
      ],
      "Type": "Task"
    }
  }
}
